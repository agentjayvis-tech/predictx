# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/predictx

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── External APIs ─────────────────────────────────────────────────────────────
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

OPENWEATHERMAP_KEY=your_openweathermap_key_here
OPENWEATHERMAP_BASE_URL=https://api.openweathermap.org/data/2.5

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Resolution settings ───────────────────────────────────────────────────────
RESOLUTION_CHECK_INTERVAL_SECONDS=60
DISPUTE_WINDOW_MINUTES=15
AI_CONFIDENCE_THRESHOLD=0.95
INSURANCE_FUND_FEE_BPS=50        # 0.5% of market pool

# ── Judge settings ────────────────────────────────────────────────────────────
JUDGE_DECISION_DEADLINE_HOURS=48
