# Settlement Service environment configuration
# Copy to .env and populate values before running

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8003
GRPC_PORT=9003
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://settlement_user:settlement_pass@localhost:5432/settlement_db?sslmode=disable
DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/3
REDIS_POSITION_TTL_SECONDS=120

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_ORDER_MATCHED=order.matched
KAFKA_TOPIC_MARKETS_RESOLVED=markets.resolved
KAFKA_TOPIC_MARKET_VOIDED=market.voided
KAFKA_GROUP_ID=settlement-service

# ── Wallet Service (gRPC) ────────────────────────────────────────────────────
WALLET_SERVICE_ADDR=wallet-service:9002

# ── Settlement config ─────────────────────────────────────────────────────────
# UUID of the platform insurance fund wallet (must exist in Wallet Service)
PLATFORM_WALLET_ID=00000000-0000-0000-0000-000000000001
DEFAULT_CURRENCY=COINS
PAYOUT_WORKERS=10

# ── Fraud detection ───────────────────────────────────────────────────────────
FRAUD_BET_WINDOW_SECS=60
FRAUD_CONCENTRATION_LIMIT=50
FRAUD_LARGE_STAKE_MINOR=1000000
