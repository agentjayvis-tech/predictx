# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/predictx?sslmode=disable
DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_BALANCE_TTL_SECONDS=5

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PAYMENTS_COMPLETED=payments.completed

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8002
GRPC_PORT=9002
LOG_LEVEL=info  # debug | info | warn | error

# ── Fraud Detection ───────────────────────────────────────────────────────────
# Max balance changes per wallet per 60 seconds before alert
FRAUD_MAX_CHANGES_PER_MIN=10
# Single credit amount (in minor units) that triggers a large_credit alert
FRAUD_LARGE_CREDIT_THRESHOLD=100000
# % balance drop in 5 minutes that triggers a rapid_drain alert (0-100)
FRAUD_RAPID_DRAIN_PCT=80

# ── Gamification ──────────────────────────────────────────────────────────────
# Daily reward COINS granted to active users
DAILY_REWARD_COINS=100
