# ═════════════════════════════════════════════════════════════════════════════════
# Order Service Configuration
# Copy to .env and fill in values for local development
# ═════════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────────
PORT=8003
GRPC_PORT=9003
LOG_LEVEL=info  # debug | info | warn | error

# ─── Database ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/order_test?sslmode=disable
DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2

# ─── Redis ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1
REDIS_ORDER_TTL_SECONDS=60
REDIS_RG_LIMIT_TTL_SECONDS=1800

# ─── Kafka ────────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_ORDERS_PLACED=orders.placed
KAFKA_TOPIC_ORDERS_CANCELLED=orders.cancelled
KAFKA_TOPIC_MARKET_VOIDED=markets.voided
KAFKA_TOPIC_ORDERS_MATCHED=orders.matched
KAFKA_CONSUMER_GROUP_MARKET_VOIDED=order-service-market-voided
KAFKA_CONSUMER_GROUP_ORDERS_MATCHED=order-service-orders-matched

# ─── gRPC Clients (Other Services) ───────────────────────────────────────────────
WALLET_SERVICE_ADDR=wallet-service:9002
MARKET_SERVICE_ADDR=market-service:9001
GRPC_TIMEOUT_SECS=10

# ─── Rate Limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_ORDERS_PER_MIN=100

# ─── Responsible Gambling (RG) Limits ──────────────────────────────────────────────
RG_DAILY_LIMIT_COINS=10000
RG_WEEKLY_LIMIT_COINS=50000
