# ── HTTP / gRPC ────────────────────────────────────────────────────────────────
PORT=8004
GRPC_PORT=9004

# ── PostgreSQL 17 ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://matching_user:matching_pass@localhost:5432/matching_db
DATABASE_MAX_CONNECTIONS=20

# ── Redis 8 ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=matching-engine

# Topics consumed
KAFKA_TOPIC_ORDERS_PLACED=orders.placed
KAFKA_TOPIC_MARKET_VOIDED=market.voided

# Topics produced
KAFKA_TOPIC_TRADES_MATCHED=trades.matched

# ── AMM (LMSR) ─────────────────────────────────────────────────────────────────
# Liquidity parameter b: higher = deeper liquidity, higher platform risk
# Recommended range: 50 (low-volume) – 500 (high-volume markets)
AMM_LIQUIDITY_B=100.0
# Default number of outcomes per market (2 = binary YES/NO)
AMM_DEFAULT_OUTCOMES=2

# ── RocksDB WAL ────────────────────────────────────────────────────────────────
# Local write-ahead log path for event sourcing / crash recovery
WAL_PATH=/data/wal

# ── Logging ────────────────────────────────────────────────────────────────────
# One of: trace, debug, info, warn, error
LOG_LEVEL=info
