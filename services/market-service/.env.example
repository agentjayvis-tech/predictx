# Server
PORT=8001
GRPC_PORT=9001
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/predictx?sslmode=disable
DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MARKET_TTL_SECONDS=60

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_MARKET_CREATED=market.created
KAFKA_TOPIC_MARKET_VOIDED=market.voided
KAFKA_TOPIC_MARKETS_RESOLVED=markets.resolved
KAFKA_GROUP_ID=market-service
